# Auto Claude data directory
.auto-claude/

# Claude Code worktrees (transient agent workspaces)
.claude/worktrees/

# Playwright CLI debug artifacts
.playwright-cli/

# Local scanner challenge runs
.scanner-challenge/

# Old git backups (kept locally only, never committed)
_git-backups/

# Phase cleanup runs: timestamped artifacts (keep runbooks + scripts, drop reports)
scripts/phase*-report-*.json
scripts/phase*-state-*.json
scripts/phase*-dynamodb-report-*.json

# Stray screenshot artifacts at repo root
post-cleanup-*.png

# U2: Playwright auth state for console.cera.buzz — production-safe test
# account credentials. Never commit. See
# docs/CERAGON_POST_SCHEMA_RETEST_ISSUE_FIX_PLAN_2026-05-07.md §U2.
docs/test-evidence/.auth/
**/console.cera.buzz.storageState.json

# Nested component git repos — each lives in its own GitHub remote
# (Ceragon-Prod/Backend, /Installers, /Frontend, /Static-Worker,
# /Sandbox-Worker, /Ceragon-Intelligence, /GithubApp-Bot-Scanner-Worker).
# This workspace meta-repo only tracks workspace-level scripts/docs.
/Backend/
/Ceragon-Intelligence/
/Frontend/
/GithubApp-Bot-Scanner-Worker/
/Installers/
/Sandbox-Worker/
/Static-Worker/

# Playwright MCP debug artifacts
.playwright-mcp/

# docs/ is a separate git repo (Ceragon-Prod/docs)
/docs/

# Built output of @ceragon/shared-contracts (regenerated by tsc)
packages/shared-contracts/dist/

# node_modules anywhere in the workspace
**/node_modules/

# .claude tooling state (machine-local — settings, plans, worktrees)
.claude/
**/.claude/

# Build outputs
**/dist/
**/.next/
**/build/

# Lockfiles for ad-hoc workspace package.json experiments (component
# repos manage their own lockfiles inside their git remotes).
packages/shared-contracts/package-lock.json
